APP_ENV=dev
APP_NAME=multi-agent-coach
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://coach:coach@localhost:5432/coach
REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_COACH=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# LangSmith / LangChain tracing（可选；本地需要真实 API Key 才会上报）
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=multi-agent-coach
# 兼容旧 LangChain 命名
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=multi-agent-coach

FIRECRAWL_API_KEY=fc-replace-me

# Clerk（从 Dashboard → Developers → API Keys 拿）
CLERK_PUBLISHABLE_KEY=pk_test_replacethis  # 仅前端用，备忘
CLERK_SECRET_KEY=sk_test_replacethis       # 后端用，务必保密
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----
从 Dashboard → JWT Templates → Copy public key 粘贴到这里
-----END PUBLIC KEY-----"
CLERK_ISSUER=https://clerk.yourapp.accounts.dev  # 从 Dashboard → JWT Templates 看
# 二选一：优先配置 JWT Template 的 aud；Clerk session token 可用 azp 校验前端来源
CLERK_JWT_AUDIENCE=multi-agent-coach
CLERK_AUTHORIZED_PARTY=

CORS_ORIGINS=["http://localhost:3000"]

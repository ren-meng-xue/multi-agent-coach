#!/usr/bin/env python3
"""
sync-protocol — audit and synchronize Agent OS protocol references.

Safe defaults:
- audit / stale / orphans are read-only.
- update-index only appends missing .ai/memory/MEMORY.md entries.
- sync reports what can be changed and only performs safe index additions.
- propose is read-only and prints a change proposal.
- apply requires --confirmed and only applies supported mechanical changes.
"""

from __future__ import annotations

import argparse
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path

import yaml


ROOT = Path(__file__).resolve().parents[2]
AI_DIR = ROOT / ".ai"
MEMORY_DIR = AI_DIR / "memory"
MEMORY_INDEX = MEMORY_DIR / "MEMORY.md"
AGENTS_DIR = AI_DIR / "agents"
WORKFLOWS_DIR = AI_DIR / "workflows"
PROMPTS_DIR = AI_DIR / "prompts"
CLAUDE_MD = ROOT / "CLAUDE.md"
CLAUDE_SKILLS_DIR = ROOT / ".claude" / "skills"


@dataclass
class Finding:
    category: str
    level: str
    where: str
    message: str

    def line(self) -> str:
        return f"[{self.level}] {self.where}: {self.message}"


@dataclass
class ProposedChange:
    kind: str
    target: str
    summary: str
    guarded: bool = False

    def line(self) -> str:
        prefix = "GUARDED" if self.guarded else "AUTO"
        return f"[{prefix}] {self.kind}: {self.target} — {self.summary}"


def rel(path: Path) -> str:
    try:
        return str(path.relative_to(ROOT))
    except ValueError:
        return str(path)


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def extract_markdown_paths(path: Path) -> list[tuple[int, str]]:
    if not path.is_file():
        return []
    refs: list[tuple[int, str]] = []
    text = read_text(path)
    patterns = [
        re.compile(r"`((?:\.?/)?(?:\.ai|docs|backend|frontend|scripts|CLAUDE\.md|README\.md|AGENTS\.md)[^` \n)]*)`"),
        re.compile(r"\]\(([^)#]+)(?:#[^)]+)?\)"),
    ]
    for lineno, line in enumerate(text.splitlines(), start=1):
        for pattern in patterns:
            for match in pattern.finditer(line):
                raw = match.group(1).strip()
                if not raw or "://" in raw or raw.startswith("#"):
                    continue
                if "*" in raw or "<" in raw or ">" in raw:
                    continue
                refs.append((lineno, raw))
    return refs


def resolve_ref(source: Path, raw: str) -> Path:
    raw = raw.strip().strip("<>")
    if raw.startswith("./"):
        return (ROOT / raw[2:]).resolve()
    if raw.startswith(".ai/") or raw in {"CLAUDE.md", "README.md", "AGENTS.md"}:
        return (ROOT / raw).resolve()
    if raw.startswith(("../", "/")):
        return (source.parent / raw).resolve()
    return (source.parent / raw).resolve()


def check_claude_refs() -> list[Finding]:
    findings: list[Finding] = []
    if not CLAUDE_MD.is_file():
        return [Finding("CLAUDE.md 引用", "ERROR", "CLAUDE.md", "文件不存在")]
    for lineno, raw in extract_markdown_paths(CLAUDE_MD):
        target = resolve_ref(CLAUDE_MD, raw)
        if not target.exists():
            findings.append(
                Finding("CLAUDE.md 引用", "ERROR", f"CLAUDE.md:{lineno}", f"引用不存在: `{raw}`")
            )
    return findings


def parse_memory_index() -> tuple[set[str], list[Finding]]:
    findings: list[Finding] = []
    indexed: set[str] = set()
    if not MEMORY_INDEX.is_file():
        return indexed, [Finding("MEMORY.md", "ERROR", rel(MEMORY_INDEX), "索引文件不存在")]

    for lineno, line in enumerate(read_text(MEMORY_INDEX).splitlines(), start=1):
        for match in re.finditer(r"\[([^\]]+\.md)\]\(([^)]+\.md)\)", line):
            target = match.group(2).strip()
            indexed.add(target)
            if not (MEMORY_DIR / target).is_file():
                findings.append(
                    Finding("MEMORY.md", "ERROR", f"{rel(MEMORY_INDEX)}:{lineno}", f"索引引用不存在文件 `{target}`")
                )
    return indexed, findings


def check_memory_index() -> list[Finding]:
    indexed, findings = parse_memory_index()
    actual = {
        path.name
        for path in MEMORY_DIR.glob("*.md")
        if path.is_file() and path.name != "MEMORY.md"
    }
    for name in sorted(actual - indexed):
        findings.append(Finding("MEMORY.md", "WARN", rel(MEMORY_DIR / name), "存在但未被 MEMORY.md 索引"))
    return findings


def check_agent_context() -> list[Finding]:
    findings: list[Finding] = []
    actual = {
        path.name
        for path in MEMORY_DIR.glob("*.md")
        if path.is_file() and path.name != "MEMORY.md"
    }
    for agent in sorted(AGENTS_DIR.glob("*.md")):
        if agent.name == "README.md":
            continue
        in_context = False
        for lineno, line in enumerate(read_text(agent).splitlines(), start=1):
            stripped = line.strip()
            if stripped.startswith("## Context"):
                in_context = True
                continue
            if in_context and stripped.startswith("## "):
                in_context = False
                continue
            if not in_context:
                continue
            for token in re.findall(r"\b([a-z][a-z-]*[a-z])\.md\b", line):
                ref = f"{token}.md"
                if ref not in actual:
                    findings.append(
                        Finding("Agent Context", "ERROR", f"{rel(agent)}:{lineno}", f"引用不存在 memory `{ref}`")
                    )
    return findings


def check_workflow_owners() -> list[Finding]:
    findings: list[Finding] = []
    agents = {path.stem for path in AGENTS_DIR.glob("*.md") if path.name != "README.md"}
    allowed_dynamic = {"current_agent"}
    for workflow in sorted(WORKFLOWS_DIR.glob("*.yaml")):
        try:
            data = yaml.safe_load(read_text(workflow)) or {}
        except yaml.YAMLError as exc:
            findings.append(Finding("Workflow owners", "ERROR", rel(workflow), f"YAML 解析失败: {exc}"))
            continue
        steps = data.get("steps") or {}
        for step_name, step in steps.items():
            owners = []
            if isinstance(step, dict):
                if step.get("owner"):
                    owners.append(step["owner"])
                owners.extend(step.get("owners") or [])
            for owner in owners:
                if owner in allowed_dynamic:
                    continue
                if owner not in agents:
                    findings.append(
                        Finding("Workflow owners", "ERROR", rel(workflow), f"step `{step_name}` owner `{owner}` 没有对应 agent 文件")
                    )
    return findings


def check_prompt_refs() -> list[Finding]:
    findings: list[Finding] = []
    sources = [CLAUDE_MD, *sorted(AGENTS_DIR.glob("*.md"))]
    for source in sources:
        if not source.is_file():
            continue
        for lineno, raw in extract_markdown_paths(source):
            if ".ai/prompts/" not in raw and not raw.startswith("../prompts/"):
                continue
            target = resolve_ref(source, raw)
            if not target.exists():
                findings.append(
                    Finding("Prompts", "ERROR", f"{rel(source)}:{lineno}", f"模板引用不存在: `{raw}`")
                )
    return findings


def expected_claude_skill_wrapper(name: str) -> str:
    rule_path = f".ai/skills/{name}.md"
    command_hint = "<operation>"
    if name == "sync-protocol":
        command_hint = "<audit|sync|propose|apply --confirmed|orphans|stale|update-index>"
    return f"""---
description: Project skill entry. Full rules live in {rule_path}.
argument-hint: \"{command_hint}\"
disable-model-invocation: true
---

# {name}

本文件只是 Claude Code 的 skill 注册入口。

完整规则以项目协议文件为唯一来源：

```text
{rule_path}
```

执行前必须先读取该文件，并遵守其中的触发方式、写入边界、二次确认和删除规则。
"""


def skill_wrapper_changes() -> list[ProposedChange]:
    changes: list[ProposedChange] = []
    for skill_file in sorted((AI_DIR / "skills").glob("*.md")):
        name = skill_file.stem
        wrapper = CLAUDE_SKILLS_DIR / name / "SKILL.md"
        expected = expected_claude_skill_wrapper(name)
        if not wrapper.is_file():
            changes.append(
                ProposedChange(
                    "claude-skill-wrapper",
                    rel(wrapper),
                    f"为 .ai/skills/{skill_file.name} 创建 Claude Code 注册入口",
                )
            )
            continue
        current = read_text(wrapper)
        if current != expected:
            changes.append(
                ProposedChange(
                    "claude-skill-wrapper",
                    rel(wrapper),
                    f"收敛为薄入口，规则正文指向 .ai/skills/{skill_file.name}",
                )
            )
    return changes


def memory_index_changes() -> list[ProposedChange]:
    actual = {
        path.name
        for path in MEMORY_DIR.glob("*.md")
        if path.is_file() and path.name != "MEMORY.md"
    }
    indexed, findings = parse_memory_index()
    changes = [
        ProposedChange(
            "memory-index",
            rel(MEMORY_INDEX),
            f"补全缺失索引: {name}",
        )
        for name in sorted(actual - indexed)
    ]
    for finding in findings:
        changes.append(
            ProposedChange(
                "memory-index",
                rel(MEMORY_INDEX),
                finding.message,
                guarded=True,
            )
        )
    for name in sorted(indexed - actual):
        changes.append(
            ProposedChange(
                "memory-index",
                rel(MEMORY_INDEX),
                f"索引指向不存在文件，需要确认是否删除: {name}",
                guarded=True,
            )
        )
    return changes


def proposed_changes() -> tuple[list[ProposedChange], list[Finding]]:
    changes: list[ProposedChange] = []
    changes.extend(memory_index_changes())
    changes.extend(skill_wrapper_changes())
    audit_findings = all_audit_findings()
    guarded_findings = [
        finding
        for finding in audit_findings
        if finding.category != "MEMORY.md"
    ]
    return changes, guarded_findings


def print_proposal() -> int:
    changes, guarded_findings = proposed_changes()
    print("=== Sync-Protocol Proposal ===")
    if not changes and not guarded_findings:
        print("✓ 无需同步")
        return 0

    auto_changes = [change for change in changes if not change.guarded]
    guarded_changes = [change for change in changes if change.guarded]

    if auto_changes:
        print("\n可在确认后自动应用:")
        for change in auto_changes:
            print(change.line())
    if guarded_changes or guarded_findings:
        print("\n需要人工确认或手动处理:")
        for change in guarded_changes:
            print(change.line())
        for finding in guarded_findings:
            print(f"[GUARDED] {finding.category}: {finding.where} — {finding.message}")

    print("\n应用可自动项:")
    print(".ai/bin/sync-protocol apply --confirmed")
    return 2 if guarded_changes or guarded_findings else 0


def write_claude_skill_wrappers() -> int:
    wrote = 0
    for change in skill_wrapper_changes():
        if change.guarded:
            continue
        name = Path(change.target).parent.name
        wrapper = ROOT / change.target
        wrapper.parent.mkdir(parents=True, exist_ok=True)
        wrapper.write_text(expected_claude_skill_wrapper(name), encoding="utf-8")
        print(f"[WRITE] {change.target}")
        wrote += 1
    if wrote == 0:
        print("✓ Claude skill 注册入口无需更新")
    return 0


def all_audit_findings() -> list[Finding]:
    findings: list[Finding] = []
    findings.extend(check_claude_refs())
    findings.extend(check_agent_context())
    findings.extend(check_memory_index())
    findings.extend(check_workflow_owners())
    findings.extend(check_prompt_refs())
    return findings


def print_audit(findings: list[Finding]) -> int:
    categories = [
        "CLAUDE.md 引用",
        "Agent Context",
        "MEMORY.md",
        "Workflow owners",
        "Prompts",
    ]
    print("=== Sync-Protocol Audit ===")
    for category in categories:
        items = [f for f in findings if f.category == category]
        errors = [f for f in items if f.level == "ERROR"]
        warns = [f for f in items if f.level == "WARN"]
        if not items:
            print(f"✓ {category}: 通过")
        else:
            print(f"! {category}: {len(errors)} error(s), {len(warns)} warning(s)")
    print()
    for finding in findings:
        print(finding.line())
    errors = [f for f in findings if f.level == "ERROR"]
    warns = [f for f in findings if f.level == "WARN"]
    print(f"\n--- {len(errors)} error(s), {len(warns)} warning(s)")
    return 1 if errors else (2 if warns else 0)


def stale() -> int:
    findings = [
        f for f in all_audit_findings()
        if "不存在" in f.message or "引用不存在" in f.message
    ]
    if not findings:
        print("=== Sync-Protocol Stale ===")
        print("✓ 未发现过期引用")
        return 0
    print("=== Sync-Protocol Stale ===")
    for finding in findings:
        print(finding.line())
    return 1 if any(f.level == "ERROR" for f in findings) else 2


def referenced_ai_paths() -> set[Path]:
    refs: set[Path] = set()
    sources = [CLAUDE_MD, *AI_DIR.rglob("*.md"), *AI_DIR.rglob("*.yaml")]
    for source in sources:
        if not source.is_file():
            continue
        text = read_text(source)
        for raw in re.findall(r"(?:`|\(|\s)(\.ai/[A-Za-z0-9_./-]+)", text):
            target = (ROOT / raw.rstrip("`) .,")).resolve()
            refs.add(target)
            if target.is_dir():
                refs.update(path.resolve() for path in target.rglob("*") if path.is_file())
        if source == MEMORY_INDEX:
            indexed, _ = parse_memory_index()
            for name in indexed:
                refs.add((MEMORY_DIR / name).resolve())

    # Workflow files are discovered by convention; owners reference agent masks.
    for workflow in WORKFLOWS_DIR.glob("*.yaml"):
        refs.add(workflow.resolve())
        try:
            data = yaml.safe_load(read_text(workflow)) or {}
        except yaml.YAMLError:
            continue
        for step in (data.get("steps") or {}).values():
            if not isinstance(step, dict):
                continue
            owners = []
            if step.get("owner"):
                owners.append(step["owner"])
            owners.extend(step.get("owners") or [])
            for owner in owners:
                agent_path = AGENTS_DIR / f"{owner}.md"
                if agent_path.is_file():
                    refs.add(agent_path.resolve())

    # CLI and library files under .ai/bin and .ai/lib are executable/discoverable tools.
    for tool_file in (AI_DIR / "bin").glob("*"):
        if tool_file.is_file():
            refs.add(tool_file.resolve())
    for lib_file in (AI_DIR / "lib").rglob("*.py"):
        refs.add(lib_file.resolve())
    return refs


def orphans() -> int:
    refs = referenced_ai_paths()
    ignored_parts = {"tasks", "__pycache__"}
    files = [
        path
        for path in AI_DIR.rglob("*")
        if path.is_file()
        and path.suffix != ".bak"
        and not any(part in ignored_parts for part in path.relative_to(AI_DIR).parts)
    ]
    orphaned = [path for path in files if path.resolve() not in refs and path.name != "README.md"]
    print("=== Sync-Protocol Orphans ===")
    if not orphaned:
        print("✓ 未发现孤立文件")
        return 0
    for path in sorted(orphaned):
        print(f"[WARN] {rel(path)}: 未被 CLAUDE.md / MEMORY.md / workflow / agent context 明确引用")
    return 2


def update_index() -> int:
    print("=== Sync-Protocol Update Index ===")
    actual = {
        path.name
        for path in MEMORY_DIR.glob("*.md")
        if path.is_file() and path.name != "MEMORY.md"
    }
    indexed, findings = parse_memory_index()
    missing = sorted(actual - indexed)
    stale_entries = sorted(indexed - actual)

    if missing:
        print("将写入目标: .ai/memory/MEMORY.md")
        print("将补全索引:")
        for name in missing:
            print(f"- {name}")
        result = subprocess.run(
            ["bash", str(AI_DIR / "bin" / "sync-memory"), "update-index"],
            cwd=ROOT,
            text=True,
        )
        if result.returncode != 0:
            return result.returncode
    else:
        print("✓ 无缺失 memory 索引")

    if stale_entries:
        print()
        print("需要用户确认后才能删除的孤立索引:")
        for name in stale_entries:
            print(f"- {name}")

    for finding in findings:
        print(finding.line())
    return 2 if stale_entries or findings else 0


def sync() -> int:
    findings = all_audit_findings()
    print_audit(findings)
    print("\n=== Sync-Protocol Sync Plan ===")
    safe_missing_index = [
        f for f in findings
        if f.category == "MEMORY.md" and "存在但未被 MEMORY.md 索引" in f.message
    ]
    guarded = [
        f for f in findings
        if f not in safe_missing_index
    ]

    if safe_missing_index:
        print("可自动写入目标: .ai/memory/MEMORY.md（只补缺失索引）")
        code = update_index()
        if code == 1:
            return code
    else:
        print("无可自动写入项")

    if guarded:
        print("\n以下问题涉及删除、协议核心、路径修正或行为边界，必须用户确认后处理:")
        for finding in guarded:
            print(finding.line())
        return 2
    return 0


def apply_confirmed(confirmed: bool) -> int:
    if not confirmed:
        print("ERROR: apply 必须显式传入 --confirmed")
        print("先执行: .ai/bin/sync-protocol propose")
        return 1

    changes, guarded_findings = proposed_changes()
    auto_changes = [change for change in changes if not change.guarded]
    if not auto_changes:
        print("✓ 无可自动应用项")
    else:
        if any(change.kind == "memory-index" for change in auto_changes):
            code = update_index()
            if code == 1:
                return code
        if any(change.kind == "claude-skill-wrapper" for change in auto_changes):
            code = write_claude_skill_wrappers()
            if code != 0:
                return code

    guarded_changes = [change for change in changes if change.guarded]
    if guarded_changes or guarded_findings:
        print("\n以下项目未自动应用，需要人工确认或手动处理:")
        for change in guarded_changes:
            print(change.line())
        for finding in guarded_findings:
            print(f"[GUARDED] {finding.category}: {finding.where} — {finding.message}")
        return 2

    return print_audit(all_audit_findings())


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Sync Agent OS protocol references")
    parser.add_argument("command", choices=["audit", "sync", "propose", "apply", "orphans", "stale", "update-index"])
    parser.add_argument("--confirmed", action="store_true", help="required for apply")
    args = parser.parse_args(argv)

    if args.command == "audit":
        return print_audit(all_audit_findings())
    if args.command == "sync":
        return sync()
    if args.command == "propose":
        return print_proposal()
    if args.command == "apply":
        return apply_confirmed(args.confirmed)
    if args.command == "orphans":
        return orphans()
    if args.command == "stale":
        return stale()
    if args.command == "update-index":
        return update_index()
    return 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

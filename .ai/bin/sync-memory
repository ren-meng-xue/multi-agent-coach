#!/usr/bin/env bash
#
# sync-memory — 记忆文件操作工具
#
# 用法：
#   bash .ai/bin/sync-memory write    <file.md> <section_title> [content]
#   bash .ai/bin/sync-memory overwrite <file.md> <section_title> [content]
#   bash .ai/bin/sync-memory append   <file.md> [content]
#   bash .ai/bin/sync-memory check    <file.md>
#   bash .ai/bin/sync-memory update-index
#
# content 可通过最后一个参数或 stdin 传入（参数优先于 stdin）。

set -euo

MEMORY_DIR="$(cd "$(dirname "$0")/../memory" && pwd)"
INDEX_FILE="$MEMORY_DIR/MEMORY.md"

die() { echo "[ERROR] $*" >&2; exit 1; }
info() { echo "[INFO] $*" >&2; }

# 校验文件名安全：拒绝路径遍历和绝对路径
validate_filename() {
    local name="$1"
    [[ -n "$name" ]] || die "文件名不能为空"
    [[ "$name" =~ ^/ ]] && die "拒绝绝对路径: $name"
    [[ "$name" =~ \.\. ]] && die "拒绝路径遍历: $name"
    [[ "$name" =~ / ]] && die "拒绝子目录路径: $name"
    [[ "$name" == MEMORY.md ]] && die "禁止直接操作 MEMORY.md"
}

# ── 工具函数 ──

ensure_file() {
    local f="$1"
    [[ -f "$f" ]] || touch "$f"
}

# 获取内容：参数优先，stdin 次之
get_content() {
    local arg="${1:-}"
    if [[ -n "$arg" ]]; then
        echo "$arg"
    elif [[ ! -t 0 ]]; then
        cat
    else
        die "content 不能为空（通过参数或 stdin 传入）"
    fi
}

# 检查 section 是否存在，输出行号范围 "start:end"
find_section() {
    local file="$1" title="$2"
    local start_line end_line

    # 匹配 "## <title>" 行（可带后缀如 " — ..."）
    start_line=$(grep -n "^## ${title}" "$file" | head -1 | cut -d: -f1)
    [[ -n "$start_line" ]] || return 1

    # 找下一个同级 ## 标题
    end_line=$(tail -n +"$((start_line + 1))" "$file" | grep -n "^## " | head -1 | cut -d: -f1)
    if [[ -z "$end_line" ]]; then
        echo "${start_line}:\$"
    else
        echo "${start_line}:$((start_line + end_line - 1))"
    fi
}

# 确保 MEMORY.md 中有该文件的条目（已有则保留人工描述不动）
refresh_index() {
    local filename="$1"
    local fpath="$MEMORY_DIR/$filename"
    ensure_file "$INDEX_FILE"

    local existing
    existing=$(grep -E "\[${filename}\]\(${filename}\)" "$INDEX_FILE" | head -1 || true)

    if [[ -z "$existing" ]]; then
        # 新增条目，用 h1 标题作为初始描述
        local title
        title=$(head -1 "$fpath" 2>/dev/null | sed 's/^# //;s/[[:space:]]*$//' || true)
        if grep -qE '^\|.*文件.*\|' "$INDEX_FILE"; then
            echo "| [${filename}](${filename}) | 按需加载 | ${title} |" >> "$INDEX_FILE"
        else
            echo "- [${filename}](${filename}) — ${title}" >> "$INDEX_FILE"
        fi
        info "MEMORY.md 新增索引: $filename"
    fi
}

# ── 核心写操作 ──

# 向文件末尾追加内容块
_do_append() {
    local fpath="$1" content="$2"
    local date_tag
    date_tag=$(date -u '+%Y-%m-%d')

    {
        cat "$fpath"
        echo ""
        echo "## ${date_tag}"
        echo ""
        echo "$content"
    } > "${fpath}.tmp"
    mv "${fpath}.tmp" "$fpath"
}

# 覆盖或新增 section
_do_upsert() {
    local fpath="$1" title="$2" content="$3"
    local date_tag
    date_tag=$(date -u '+%Y-%m-%d')

    local range
    if range=$(find_section "$fpath" "$title"); then
        local start_line end_line
        start_line=$(echo "$range" | cut -d: -f1)
        end_line=$(echo "$range" | cut -d: -f2)

        local tmp
        tmp=$(mktemp)
        head -n "$((start_line - 1))" "$fpath" > "$tmp"
        {
            echo "## ${title}"
            echo ""
            echo "$content"
            echo ""
            echo "*(更新于 ${date_tag})*"
        } >> "$tmp"
        if [[ "$end_line" != "\$" ]]; then
            tail -n "+$((end_line + 1))" "$fpath" >> "$tmp"
        fi
        mv "$tmp" "$fpath"
        info "覆盖 section '$title' ($(basename "$fpath"))"
    else
        {
            cat "$fpath"
            echo ""
            echo "## ${title}"
            echo ""
            echo "$content"
            echo ""
            echo "*(添加于 ${date_tag})*"
        } > "${fpath}.tmp"
        mv "${fpath}.tmp" "$fpath"
        info "新增 section '$title' ($(basename "$fpath"))"
    fi
}

# ── 命令 ──

cmd_check() {
    local file="$1"
    validate_filename "$file"
    local fpath="$MEMORY_DIR/$file"
    [[ -f "$fpath" ]] || die "文件不存在: $fpath"

    echo "=== Memory Check: $file ==="
    echo "路径: $fpath"
    echo "大小: $(wc -c < "$fpath" | tr -d ' ') bytes, $(wc -l < "$fpath" | tr -d ' ') lines"
    echo "最后修改: $(date -r "$fpath" '+%Y-%m-%d %H:%M:%S')"

    local idx
    idx=$(grep -E "^- \[${file}\]" "$INDEX_FILE" | head -1 || true)
    if [[ -n "$idx" ]]; then
        echo "索引: $idx"
    else
        echo "警告: 未被 MEMORY.md 索引"
    fi

    grep -q "^# " "$fpath" || echo "警告: 缺少一级标题"
}

cmd_append() {
    local file="$1"
    validate_filename "$file"
    local content
    content=$(get_content "${2:-}")
    local fpath="$MEMORY_DIR/$file"
    ensure_file "$fpath"

    _do_append "$fpath" "$content"
    info "追加到 $file"
    refresh_index "$file"
}

cmd_overwrite() {
    local file="$1" title="$2"
    validate_filename "$file"
    local content
    content=$(get_content "${3:-}")
    local fpath="$MEMORY_DIR/$file"
    ensure_file "$fpath"

    _do_upsert "$fpath" "$title" "$content"
    refresh_index "$file"
}

cmd_write() {
    local file="$1" title="$2"
    validate_filename "$file"
    local content
    content=$(get_content "${3:-}")
    local fpath="$MEMORY_DIR/$file"
    ensure_file "$fpath"

    if find_section "$fpath" "$title" > /dev/null 2>&1; then
        info "检测到冲突: section '$title' 已存在于 $file → 覆盖旧内容"
    else
        info "无冲突: section '$title' 不存在 → 新增"
    fi
    _do_upsert "$fpath" "$title" "$content"
    refresh_index "$file"
}

cmd_update_index() {
    info "更新 MEMORY.md 索引（保留已有描述）..."
    ensure_file "$INDEX_FILE"

    # 收集实际存在的 memory 文件
    local actual_files
    actual_files=$(for f in "$MEMORY_DIR"/*.md; do
        local n; n=$(basename "$f")
        [[ "$n" == "MEMORY.md" ]] && continue
        echo "$n"
    done)

    # 已有索引条目
    local indexed_files
    indexed_files=$(grep -Eo '\[[^]]+\.md\]\([^)]+\.md\)' "$INDEX_FILE" 2>/dev/null \
        | sed 's/.*(\([^)]*\.md\)).*/\1/' || true)

    # 新增缺失条目
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if ! echo "$indexed_files" | grep -qF "$name"; then
            local title
            title=$(head -1 "$MEMORY_DIR/$name" 2>/dev/null | sed 's/^# //;s/[[:space:]]*$//' || true)
            if grep -qE '^\|.*文件.*\|' "$INDEX_FILE"; then
                echo "| [${name}](${name}) | 按需加载 | ${title} |" >> "$INDEX_FILE"
            else
                echo "- [${name}](${name}) — ${title}" >> "$INDEX_FILE"
            fi
            info "新增索引: $name"
        fi
    done <<< "$actual_files"

    # 检测孤立条目
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if ! echo "$actual_files" | grep -qF "$name"; then
            info "孤立索引: $name (文件不存在)"
        fi
    done <<< "$indexed_files"

    local count
    count=$(grep -Eo '\[[^]]+\.md\]\([^)]+\.md\)' "$INDEX_FILE" 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    info "MEMORY.md (${count} 条)"
}

# ── 入口 ──

main() {
    local cmd="${1:-}"; shift || true

    case "$cmd" in
        write)
            [[ $# -ge 2 ]] || die "用法: sync-memory write <file.md> <section_title> [content]"
            cmd_write "$1" "$2" "${3:-}"
            ;;
        overwrite)
            [[ $# -ge 2 ]] || die "用法: sync-memory overwrite <file.md> <section_title> [content]"
            cmd_overwrite "$1" "$2" "${3:-}"
            ;;
        append)
            [[ $# -ge 1 ]] || die "用法: sync-memory append <file.md> [content]"
            cmd_append "$1" "${2:-}"
            ;;
        check)
            [[ $# -ge 1 ]] || die "用法: sync-memory check <file.md>"
            cmd_check "$1"
            ;;
        update-index)
            cmd_update_index
            ;;
        *)
            die "未知命令: $cmd\n可用: write | overwrite | append | check | update-index"
            ;;
    esac
}

main "$@"
